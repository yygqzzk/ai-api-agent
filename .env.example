# 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# 使用方式：source .env 或 export $(cat .env | xargs)

# ============================================
# 基础配置（必填）
# ============================================

# 认证 Token（必填）
AUTH_TOKEN="demo-token"

# ============================================
# LLM 配置
# ============================================

# OpenAI 配置（推荐用于开发测试）
LLM_API_KEY="sk-your-openai-api-key-here"
LLM_MODEL="gpt-4o-mini"
LLM_BASE_URL="https://api.openai.com"

# DeepSeek 配置（国内可用，价格便宜）
# LLM_API_KEY="your-deepseek-api-key"
# LLM_MODEL="deepseek-chat"
# LLM_BASE_URL="https://api.deepseek.com"

# Claude 配置（推理能力强）
# LLM_API_KEY="your-anthropic-api-key"
# LLM_MODEL="claude-3-5-sonnet-20241022"
# LLM_BASE_URL="https://api.anthropic.com"

# LLM 高级配置（可选）
# LLM_PROVIDER="openai"
# LLM_MAX_TOKENS="4096"
# LLM_TIMEOUT_SECONDS="30"
# LLM_MAX_RETRIES="2"
# LLM_RETRY_BACKOFF_MS="200"

# ============================================
# 存储配置（运行时必填）
# ============================================

# Milvus 配置
MILVUS_ADDRESS="localhost:19530"

# Redis 配置
REDIS_ADDRESS="localhost:6379"
# REDIS_PASSWORD=""
# REDIS_DB="0"

# ============================================
# Embedding 配置（可选）
# ============================================

# 如果不配置，将使用 LLM 的 API Key 和 Base URL
# EMBEDDING_API_KEY="your-embedding-api-key"
# EMBEDDING_BASE_URL="https://api.openai.com"
# EMBEDDING_MODEL="text-embedding-3-small"
# EMBEDDING_DIM="1536"

# ============================================
# Rerank 配置（可选）
# ============================================

# 用于对检索结果进行精准重排序，提升准确率
# 如果不配置，将使用 Embedding 或 LLM 的 API Key
# RERANK_API_KEY="your-rerank-api-key"
# RERANK_BASE_URL="https://dashscope.aliyuncs.com"
# RERANK_MODEL="qwen3-vl-rerank"

# ============================================
# 服务器配置（可选）
# ============================================

# PORT="8080"

# ============================================
# 快速配置模板
# ============================================

# 模板 1：使用真实 LLM（推荐）
# AUTH_TOKEN="test-token"
# LLM_API_KEY="sk-xxx"
# LLM_MODEL="gpt-4o-mini"
# MILVUS_ADDRESS="localhost:19530"
# REDIS_ADDRESS="localhost:6379"

# 模板 2：完整运行模式（Redis + Milvus 必需）
# AUTH_TOKEN="prod-token"
# LLM_API_KEY="sk-xxx"
# LLM_MODEL="gpt-4o-mini"
# MILVUS_ADDRESS="localhost:19530"
# REDIS_ADDRESS="localhost:6379"
